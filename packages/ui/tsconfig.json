{
  "extends": ["../../tsconfig.base.json"],
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "composite": false,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/client/*"],
      "@shared/*": ["./src/shared/*"],
      "@antimatter/project-model": ["../project-model/src/index.ts"],
      "@antimatter/filesystem": ["../filesystem/src/index.ts"],
      "@antimatter/tool-integration": ["../tool-integration/src/index.ts"],
      "@antimatter/build-system": ["../build-system/src/index.ts"],
      "@antimatter/agent-framework": ["../agent-framework/src/index.ts"],
      "@antimatter/workspace": ["../workspace/src/index.ts"],
      "@antimatter/workflow": ["../workflow/src/index.ts"],
      "@antimatter/test-utils": ["../test-utils/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../workspace"
    },
    {
      "path": "../tool-integration"
    },
    {
      "path": "../project-model"
    },
    {
      "path": "../filesystem"
    },
    {
      "path": "../build-system"
    },
    {
      "path": "../agent-framework"
    }
  ]
}
